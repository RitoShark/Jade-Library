{
  "applicationId": "com.frogtools.jadelibrary",
  "version": "0.1.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/resources/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "filesystem.*",
    "computer.*",
    "events.*",
    "debug.log",
    "window.*"
  ],
  "globalVariables": {},
  "modes": {
    "window": {
      "title": "Jade Library Extractor",
      "width": 1100,
      "height": 760,
      "minWidth": 900,
      "minHeight": 600,
      "fullScreen": false,
      "alwaysOnTop": false,
      "icon": "/resources/icons/jadejade.ico",
      "enableInspector": false,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "jade-library-extractor",
    "resourcesPath": "/resources/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/resources/js/neutralino.js",
    "binaryVersion": "5.4.0",
    "clientVersion": "5.4.0"
  }
}
